---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Navbar from '../components/Navbar';
import { IconGithub, IconLinkedin } from '../components/BrandIcons';
import { Mail } from 'lucide-react';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = 'Arash Kadkhodaei – Software Engineer',
  description = 'Software Engineer at Freiburg University, specializing in Python, backend development, and Galaxy Project bioinformatics tooling.',
  image = '/og.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
} = Astro.props;

const siteURL = Astro.site?.origin ?? 'https://kadkhodaei.de';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <!-- JS detection: hide .gsap-reveal elements before paint to prevent FOUC -->
    <script is:inline>document.documentElement.classList.add('js-enabled');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteURL)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Arash Kadkhodaei - Software Engineer" />
    <meta property="og:site_name" content="Arash Kadkhodaei" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, siteURL)} />

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/a-logo.png" />
    <link rel="icon" type="image/png" href="/a-logo.png" />

    <!-- Browser theme color (updated dynamically by dark-mode script + Navbar) -->
    <meta name="theme-color" content="#f7fcfc" />

    <!-- Fonts: Inter + JetBrains Mono (self-hosted via Astro Fonts API) -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Arash Kadkhodaei',
      url: siteURL,
      email: 'arash@kadkhodaei.de',
      sameAs: [
        'https://github.com/arash77',
        'https://linkedin.com/in/kadarash',
      ],
      jobTitle: 'Software Engineer',
      worksFor: {
        '@type': 'Organization',
        name: 'Freiburg University',
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Freiburg',
        addressCountry: 'DE',
      },
    })} />

    <!-- Dark mode init (prevent flash) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = stored === 'dark' || (!stored && prefersDark);
          if (isDark) {
            document.documentElement.classList.add('dark');
          }
          const themeColorMeta = document.querySelector('meta[name="theme-color"]');
          if (themeColorMeta) {
            themeColorMeta.setAttribute('content', isDark ? '#041618' : '#f7fcfc');
          }
        } catch (_) {}
      })();
    </script>
    <!-- Legal language init (prevent flash on legal pages) -->
    <script is:inline>
      (function () {
        try {
          var lang = localStorage.getItem('legal-lang');
          if (lang === 'en') document.documentElement.setAttribute('data-legal-lang', 'en');
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-100 focus:bg-background focus:border focus:border-primary focus:text-foreground focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-medium"
    >
      Skip to main content
    </a>
    <Navbar currentPath={Astro.url.pathname} client:load />
    <main id="main-content">
      <slot />
    </main>
    <footer class="border-t border-border py-10 mt-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
          <p class="font-mono">
            © {new Date().getFullYear()} Arash Kadkhodaei · Built with
            <a href="https://astro.build" class="text-primary underline hover:no-underline ml-1">Astro</a>
          </p>
          <div class="flex items-center gap-4">
            <a href="https://github.com/arash77" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
              <IconGithub className="h-3.5 w-3.5" aria-hidden="true" />GitHub
            </a>
            <a href="https://linkedin.com/in/kadarash" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
              <IconLinkedin className="h-3.5 w-3.5" aria-hidden="true" />LinkedIn
            </a>
            <a href="mailto:arash@kadkhodaei.de" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
              <Mail className="h-3.5 w-3.5" aria-hidden="true" />Email
            </a>
          </div>
        </div>
        <div class="flex justify-center gap-6 mt-5 pt-5 border-t border-border/50 text-xs text-muted-foreground">
          <a href="/impressum" class="hover:text-foreground transition-colors">Impressum</a>
          <a href="/datenschutz" class="hover:text-foreground transition-colors">Datenschutz</a>
        </div>
      </div>
    </footer>
  </body>
</html>
