---
import Layout from '../layouts/Layout.astro';
import { experiences, education, languages, resumeSkillTiers, conferences } from '../data/resume';
import { Download, MapPin, Mail, Briefcase, GraduationCap, BookOpen, FileText, ExternalLink, User, Globe, Code } from 'lucide-react';
import { IconGithub, IconLinkedin } from '../components/BrandIcons';
import { SITE } from '../lib/utils';
---

<Layout
  title="Resume – Arash Kadkhodaei"
  description="Interactive resume of Arash Kadkhodaei – Software Engineer, Python developer, and Galaxy bioinformatics contributor."
>
  <div class="pt-24 pb-16">
    <div class="container mx-auto px-4 max-w-5xl">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-12 animate-fade-up">
        <div class="flex items-center gap-5">
          <img
            src={SITE.avatar}
            alt="Arash Kadkhodaei"
            width="80"
            height="80"
            loading="lazy"
            decoding="async"
            class="w-20 h-20 rounded-full border-2 border-primary/30 shadow-md object-cover"
          />
          <div>
            <h1 class="text-3xl font-bold">Arash Kadkhodaei</h1>
            <p class="text-muted-foreground font-medium">Software Engineer</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-sm text-muted-foreground">
              <span class="flex items-center gap-1"><MapPin className="h-3.5 w-3.5" aria-hidden="true" />Freiburg, Germany</span>
              <a href="mailto:arash@kadkhodaei.de" class="flex items-center gap-1 hover:text-primary"><Mail className="h-3.5 w-3.5" aria-hidden="true" />arash@kadkhodaei.de</a>
              <a href="https://github.com/arash77" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 hover:text-primary"><IconGithub className="h-3.5 w-3.5" aria-hidden="true" />arash77</a>
              <a href="https://linkedin.com/in/kadarash" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 hover:text-primary"><IconLinkedin className="h-3.5 w-3.5" aria-hidden="true" />kadarash</a>
            </div>
          </div>
        </div>
        <a
          href="/assets/resume.pdf"
          download
          class="inline-flex items-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shrink-0"
        >
          <Download className="h-4 w-4" aria-hidden="true" />
          Download PDF
        </a>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">

        <!-- Left column: Summary, Languages, Tech Skills -->
        <div class="space-y-8 lg:col-span-1">

          <!-- Summary -->
          <section aria-labelledby="heading-summary" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.15s;">
            <h2 id="heading-summary" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
              <User className="h-4 w-4" aria-hidden="true" />
              Summary
            </h2>
            <p class="text-sm text-muted-foreground leading-relaxed">
              Software Engineer with expertise in Python, FastAPI, and backend systems. Contributing to the
              Galaxy Project at Freiburg University. Background in Mechatronics from Deggendorf Institute of Technology.
              Passionate about clean code, open-source, and building reliable systems.
            </p>
          </section>

          <!-- Languages -->
          <section aria-labelledby="heading-languages" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.3s;">
            <h2 id="heading-languages" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
              <Globe className="h-4 w-4" aria-hidden="true" />
              Languages
            </h2>
            <dl class="space-y-3">
              {languages.map(({ name, cefr, label }) => (
                <div class="flex items-baseline justify-between">
                  <dt class="font-semibold text-sm">{name}</dt>
                  <dd class="text-xs font-mono text-muted-foreground">
                    <span class="font-bold text-primary">{cefr}</span>
                    {' · '}{label}
                  </dd>
                </div>
              ))}
            </dl>
          </section>

          <!-- Technical Skills -->
          <section aria-labelledby="heading-skills" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.45s;">
            <h2 id="heading-skills" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
              <Code className="h-4 w-4" aria-hidden="true" />
              Technical Skills
            </h2>
            <dl class="space-y-4">
              {resumeSkillTiers.map(({ tier, skills }) => (
                <>
                  <dt class="text-xs font-mono text-muted-foreground uppercase tracking-wider">{tier}</dt>
                  <dd class="flex flex-wrap gap-1.5 mt-1.5">
                    {skills.map((skill) => (
                      <span class="text-xs bg-muted text-foreground rounded px-2 py-0.5 font-medium">{skill}</span>
                    ))}
                  </dd>
                </>
              ))}
            </dl>
          </section>
        </div>

        <!-- Right column: Experience + Education + Conferences -->
        <div class="space-y-8 lg:col-span-2">

          <!-- Experience -->
          <section aria-labelledby="heading-experience" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.2s;">
            <h2 id="heading-experience" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-6 flex items-center gap-2">
              <Briefcase className="h-4 w-4" aria-hidden="true" />
              Experience
            </h2>
            <div class="space-y-6 border-l-2 border-border">
              {experiences.map((exp) => (
                <article class="relative pl-6">
                  <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full border-2 border-primary bg-card" aria-hidden="true" />
                  <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                    <div>
                      <h3 class="font-semibold">{exp.role}</h3>
                      <p class="text-primary text-sm">{exp.company}</p>
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-muted-foreground bg-muted rounded-full px-2.5 py-1 whitespace-nowrap font-mono">
                      <time datetime={exp.dateStart}>{exp.period}</time>
                      {exp.current && <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse" aria-hidden="true" />}
                    </div>
                  </div>
                  <ul class="space-y-1">
                    {exp.description.map((p) => (
                      <li class="text-sm text-muted-foreground flex items-baseline gap-2">
                        <span class="text-primary/60 shrink-0" aria-hidden="true">•</span>{p}
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </section>

          <!-- Education -->
          <section aria-labelledby="heading-education" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.35s;">
            <h2 id="heading-education" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-6 flex items-center gap-2">
              <GraduationCap className="h-4 w-4" aria-hidden="true" />
              Education
            </h2>
            <div class="space-y-6 border-l-2 border-border">
              {education.map((edu) => (
                <article class="relative pl-6">
                  <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full border-2 border-primary bg-card" aria-hidden="true" />
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <div class="min-w-0">
                      <h3 class="font-semibold">{edu.degree} — {edu.field}</h3>
                      <p class="text-primary text-sm">{edu.institution}</p>
                    </div>
                    <div class="text-xs font-mono text-muted-foreground bg-muted rounded-full px-2.5 py-1 whitespace-nowrap shrink-0">
                      <time datetime={edu.dateStart}>{edu.period}</time>
                    </div>
                  </div>
                  {edu.note && <p class="text-xs text-muted-foreground mt-1 italic">{edu.note}</p>}
                </article>
              ))}
            </div>
          </section>

          <!-- Conference Contributions -->
          <section aria-labelledby="heading-conferences" class="rounded-xl border border-border bg-card p-6" style="animation: fade-up 0.6s ease both 0.5s;">
            <h2 id="heading-conferences" class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-6 flex items-center justify-between gap-2">
              <span class="flex items-center gap-2">
                <BookOpen className="h-4 w-4" aria-hidden="true" />
                Conference Contributions
              </span>
              <a
                href="https://orcid.org/0009-0006-2228-8123"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1 text-xs text-muted-foreground hover:text-primary transition-colors font-sans normal-case tracking-normal"
              >
                <img src="https://orcid.org/assets/vectors/orcid.logo.icon.svg" alt="ORCID" class="h-3.5 w-3.5" />
                ORCID
                <ExternalLink className="h-3 w-3" aria-hidden="true" />
              </a>
            </h2>
            <div class="space-y-5">
              {conferences.map((pub) => (
                <article class="flex gap-4">
                  <div class="p-2.5 rounded-lg bg-primary/10 h-fit shrink-0" aria-hidden="true">
                    <FileText className="h-4 w-4 text-primary" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-3 mb-1.5">
                      <p class="flex-1 min-w-0 font-semibold text-sm leading-snug">{pub.title}</p>
                      <time datetime={pub.year} class="inline-flex items-center text-xs font-mono text-muted-foreground bg-muted rounded-full px-2.5 py-1 whitespace-nowrap shrink-0">{pub.year}</time>
                    </div>
                    <div class="flex flex-wrap gap-1 mb-2">
                      {pub.types.map((t) => (
                        <span class="text-xs bg-primary/10 text-primary rounded-full px-2 py-0.5">{t}</span>
                      ))}
                    </div>
                    <p class="text-xs text-muted-foreground mb-2">
                      {pub.contributors.map((c, i) => (
                        <>
                          {i > 0 && <span>; </span>}
                          <span class={c === 'Arash Kadkhodaei' ? 'font-medium text-foreground' : ''}>{c}</span>
                        </>
                      ))}
                    </p>
                    <div class="flex flex-col gap-0.5">
                      {pub.dois.map((doi) => (
                        <a
                          href={doi.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 text-xs text-primary hover:underline font-mono break-all"
                        >
                          <ExternalLink className="h-3 w-3 shrink-0" aria-hidden="true" />
                          {doi.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>

        </div>
      </div>
    </div>
  </div>
</Layout>
